{
  "name": "ntf-yaml-editor",
  "displayName": "NTF YAML Editor PoC",
  "description": "Table editor PoC for Nablarch NTF YAML files.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:ntfYaml.editor",
    "onCommand:ntfYaml.openAsTable"
  ],
  "main": "./extension.js",
  "bin": {
    "ntf-yaml": "./bin/ntf-yaml.js"
  },
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --test test/*.test.js",
    "test:e2e": "node ./test/e2e/runTest.js"
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "ntfYaml.editor",
        "displayName": "NTF YAML Table Editor",
        "selector": [
          {
            "filenamePattern": "*.yaml"
          },
          {
            "filenamePattern": "*.ntf.yml"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "ntfYaml.openAsTable",
        "title": "NTF YAML: Open as Table"
      }
    ]
  },
  "devDependencies": {
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.7.5"
  }
}
