{
  "name": "ntf-yaml-editor",
  "displayName": "NTF YAML Editor PoC",
  "description": "Table editor PoC for Nablarch NTF YAML files.",
  "version": "0.0.1",
  "publisher": "local",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:ntfYaml.editor",
    "onCommand:ntfYaml.openAsTable",
    "onCommand:ntfYaml.generateDiffReport",
    "onCommand:ntfYaml.openCellDiff"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "main": "./extension.js",
  "bin": {
    "ntf-yaml": "./bin/ntf-yaml.js"
  },
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --test test/*.test.js",
    "test:e2e": "node ./test/e2e/runTest.js",
    "ui:screenshots": "node scripts/capture-ui-screenshots.js",
    "package:vsix": "npm run test:unit && node -e \"require('fs').mkdirSync('dist', { recursive: true })\" && vsce package --allow-missing-repository --out dist/ntf-yaml-editor-0.0.1.vsix"
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "ntfYaml.editor",
        "displayName": "NTF YAML Table Editor",
        "selector": [
          {
            "filenamePattern": "*.yaml"
          },
          {
            "filenamePattern": "*.ntf.yml"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "ntfYaml.openAsTable",
        "title": "NTF YAML: Open as Table"
      },
      {
        "command": "ntfYaml.generateDiffReport",
        "title": "NTF YAML: Generate Cell Diff Report"
      },
      {
        "command": "ntfYaml.openCellDiff",
        "title": "NTF YAML: Open Cell Diff"
      }
    ],
    "menus": {
      "scm/resourceGroup/context": [
        {
          "command": "ntfYaml.openCellDiff",
          "when": "scmProvider == git && scmResourceGroup == workingTree",
          "group": "navigation"
        },
        {
          "command": "ntfYaml.openCellDiff",
          "when": "scmProvider == git && scmResourceGroup == index",
          "group": "navigation"
        }
      ],
      "scm/resourceFolder/context": [
        {
          "command": "ntfYaml.openCellDiff",
          "when": "scmProvider == git && scmResourceGroup == workingTree",
          "group": "navigation"
        },
        {
          "command": "ntfYaml.openCellDiff",
          "when": "scmProvider == git && scmResourceGroup == index",
          "group": "navigation"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "ntfYaml.openCellDiff",
          "when": "scmProvider == git && scmResourceGroup == workingTree",
          "group": "navigation"
        },
        {
          "command": "ntfYaml.openCellDiff",
          "when": "scmProvider == git && scmResourceGroup == index",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "ntfYaml.openCellDiff",
          "when": "resourceFilename =~ /\\.ya?ml$/",
          "group": "navigation@9"
        }
      ]
    }
  },
  "devDependencies": {
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1"
  }
}
